# --- ElevenLabs ---
ELEVENLABS_API_KEY=
# Phone Numbers tab -> import Twilio number -> copy its id
ELEVENLABS_PHONE_NUMBER_ID=
# Optional: enables HMAC verification on /webhooks/post_call
ELEVENLABS_WEBHOOK_SECRET=
# LLM id for agents as ElevenLabs names it (VERIFY in docs / dashboard dropdown)
ELEVENLABS_LLM=

OPENAI_API_KEY=
OPENAI_MODEL=

# --- App ---
# ngrok https URL, no trailing slash; baked into agent tool URLs by setup_agents
PUBLIC_BASE_URL=
PORT=8000
VERTICAL_CONFIG=config/medical_imaging.json
